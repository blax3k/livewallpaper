<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top third: Set Wallpaper Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_set_wallpaper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/set_wallpaper"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_view_scenes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/view_scenes"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_reload_scenes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reload_scenes" />
    </LinearLayout>

    <!-- Middle/Bottom: Motion Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="top">

        <!-- Scroll Motion Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scroll Motion"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/toggle_scroll_motion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Gyro Motion Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Gyro Motion"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/toggle_gyro_motion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

