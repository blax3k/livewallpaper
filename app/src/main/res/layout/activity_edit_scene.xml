<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Header with scene name and save button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/scene_name_display"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/menu_ellipsis_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/more_options"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_more" />
    </LinearLayout>

    <!-- Square GLSurfaceView for scene preview -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/black"
        android:gravity="center">

        <com.example.livewallpaper.ui.editor.views.SquareGLSurfaceView
            android:id="@+id/scene_preview_gl_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </FrameLayout>

    <!-- Focus Point Slider -->
    <include layout="@layout/component_focus_controls" />

    <!-- Container for sprite selection and details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Dropdown spinner for sprite selection -->
        <LinearLayout
            android:id="@+id/sprites_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/darker_gray"
            android:padding="8dp">

            <Spinner
                android:id="@+id/sprites_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="0dp"/>

            <ImageButton
                android:id="@+id/sprite_menu_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/sprite_options"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_more"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Scrollable sprite details view -->
        <ScrollView
            android:id="@+id/sprite_details_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Position X and Y Fields (single row) -->
                <include layout="@layout/component_position_controls" />

                <!-- Scale Control with Width and Height Fields -->
                <include layout="@layout/component_scale_controls" />

                <!-- Parallax Multiplier Slider -->
                <include layout="@layout/component_parallax_controls" />

                <!-- Properties Table -->
                <TableLayout
                    android:id="@+id/sprite_properties_table"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:stretchColumns="1"></TableLayout>
            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</LinearLayout>
